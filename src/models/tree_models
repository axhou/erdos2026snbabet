import pandas as pd
import xgboost as xgb
from sklearn.ensemble import RandomForestRegressor

from src.config import DEFAULT_FEATURES


def train_ensemble_models(df: pd.DataFrame):
    """
    Train Random Forest and XGBoost on the same feature set.
    """
    df = df.copy().dropna(subset=DEFAULT_FEATURES + ["PTS", "PTS_ROLL_VAR_SIGMA2", "PTS_ROLL_MEAN_MU"])

    X = df[DEFAULT_FEATURES]
    y = df["PTS"]

    split_idx = int(len(df) * 0.8)
    X_train, y_train = X.iloc[:split_idx], y.iloc[:split_idx]

    print("Training Random Forest...")
    rf_model = RandomForestRegressor(
        n_estimators=100,
        max_depth=5,
        random_state=42,
    )
    rf_model.fit(X_train, y_train)
    df["RF_ADJUSTED_MU"] = rf_model.predict(X)

    print("Training XGBoost...")
    xgb_model = xgb.XGBRegressor(
        objective="count:poisson",
        n_estimators=100,
        learning_rate=0.05,
        max_depth=4,
        random_state=42,
    )
    xgb_model.fit(X_train, y_train)
    df["XGB_ADJUSTED_MU"] = xgb_model.predict(X)

    dispersion_ratio = df["PTS_ROLL_VAR_SIGMA2"] / df["PTS_ROLL_MEAN_MU"]
    df["RF_ADJUSTED_SIGMA2"] = df["RF_ADJUSTED_MU"] * dispersion_ratio
    df["XGB_ADJUSTED_SIGMA2"] = df["XGB_ADJUSTED_MU"] * dispersion_ratio

    return df, rf_model, xgb_model


def train_and_predict_market_xgboost_multiyr(
    df: pd.DataFrame,
    train_seasons: list[str],
    test_season: str,
):
    """
    Train XGBoost on multiple prior seasons and predict on one test season.
    """
    df = df.copy().dropna(subset=DEFAULT_FEATURES + ["PTS", "PTS_ROLL_VAR_SIGMA2", "PTS_ROLL_MEAN_MU", "SEASON"])

    train_df = df[df["SEASON"].isin(train_seasons)].copy()
    test_df = df[df["SEASON"] == test_season].copy()

    print(f"Training on seasons: {train_seasons}")
    print(f"Testing on season: {test_season}")

    X_train, y_train = train_df[DEFAULT_FEATURES], train_df["PTS"]
    X_test = test_df[DEFAULT_FEATURES]

    xgb_model = xgb.XGBRegressor(
        objective="count:poisson",
        n_estimators=150,
        learning_rate=0.05,
        max_depth=4,
        random_state=42,
    )
    xgb_model.fit(X_train, y_train)

    test_df["XGB_ADJUSTED_MU"] = xgb_model.predict(X_test)

    dispersion_ratio = test_df["PTS_ROLL_VAR_SIGMA2"] / test_df["PTS_ROLL_MEAN_MU"]
    test_df["XGB_ADJUSTED_SIGMA2"] = test_df["XGB_ADJUSTED_MU"] * dispersion_ratio

    return test_df, xgb_model
